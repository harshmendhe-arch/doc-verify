# ── App ────────────────────────────────────
APP_NAME=Document Verification API
DEBUG=false

# ── Auth ───────────────────────────────────
# Must match the key set in the frontend Settings page (stored in localStorage)
API_KEY=test-api-key-change-in-prod

# ── API Setu Credentials ───────────────────
# Register at https://www.apisetu.gov.in/
APISETU_BASE_URL=https://apisetu.gov.in
APISETU_CLIENT_ID=your-client-id
APISETU_CLIENT_SECRET=your-client-secret

# ── eDistrict Kerala ───────────────────────
EDISTRICT_KERALA_API_KEY=your-edistrict-api-key
